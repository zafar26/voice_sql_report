{
	"env": {
		"browser": true,
		"es2021": true,
		"jquery": true
	},
	"extends": "eslint:recommended",
	"parserOptions": {
		"ecmaVersion": 12,
		"sourceType": "module"
	},
	"globals": {
		"frappe": true,
		"__": true,
		"cur_frm": true,
		"XLSX": true
	},
	"rules": {
		"no-unused-vars": "warn",
		"no-console": "off"
	}
}
